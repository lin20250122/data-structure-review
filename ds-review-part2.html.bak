const navLinks = document.querySelectorAll('.nav-bar a');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(section => {
    const sectionTop = section.offsetTop;
    if (scrollY >= sectionTop - 100) current = section.getAttribute('id');
